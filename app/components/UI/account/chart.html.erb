<div id="<%= dom_id(account, :chart) %>" class="aurora-card space-y-2">
  <div class="flex justify-between flex-col-reverse lg:flex-row gap-2 px-4 pt-4 mb-2">
    <div class="space-y-2 w-full">
      <div class="flex items-center gap-1">
        <%= tag.p title, class: "text-sm font-medium text-secondary" %>

        <% if account.investment? %>
          <%= render "investments/value_tooltip", balance: account.balance_money, holdings: holdings_value_money, cash: account.cash_balance_money %>
        <% end %>
      </div>
      <div class="flex flex-row gap-2 items-baseline">
        <%= tag.p view_balance_money.format, class: "text-primary truncate aurora-mono", style: "font-size:28px;font-weight:700;letter-spacing:-.05em" %>

        <% if converted_balance_money %>
          <%= tag.p converted_balance_money.format, class: "text-sm font-medium text-secondary" %>
        <% end %>
      </div>
    </div>

    <%= form_with url: account_path(account), method: :get, data: { controller: "auto-submit-form" } do |form| %>
      <div class="flex items-center gap-2">
        <% if account.investment? %>
          <div class="aurora-select-wrap" data-controller="aurora-select">
            <%= form.select :chart_view,
              [[t(".total_value"), "balance"], [t(".holdings"), "holdings_balance"], [t(".cash"), "cash_balance"]],
              { selected: view },
              data: { "auto-submit-form-target": "auto", "aurora-select-target": "select" } %>
          </div>
        <% end %>

        <div class="aurora-select-wrap" data-controller="aurora-select">
          <%= form.select :period,
                      Period.as_options,
                      { selected: period.key },
                      data: { "auto-submit-form-target": "auto", "aurora-select-target": "select" } %>
        </div>
      </div>
    <% end %>
  </div>

  <%= turbo_frame_tag dom_id(@account, :chart_details) do %>
    <div class="px-4">
      <%= render partial: "shared/trend_change", locals: { trend: trend, comparison_label: period.comparison_label } %>
    </div>

    <div class="h-64 pb-4">
      <% if series.any? %>
        <div
        id="lineChart"
        class="w-full h-full"
        data-controller="time-series-chart"
        data-time-series-chart-data-value="<%= series.to_json %>"></div>
      <% else %>
        <div class="w-full h-full flex items-center justify-center">
          <p class="text-secondary text-sm">暂无数据</p>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
