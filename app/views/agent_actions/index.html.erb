<%= content_for :page_title, "操作日志" %>

<header class="flex items-center justify-between mb-4">
  <h1 class="text-primary text-xl font-medium">Agent 操作日志</h1>
</header>

<div class="flex items-center gap-1 mb-4 border-b border-secondary">
  <%
    tabs = [
      { key: "pending", label: "待审批", count: @pending_actions.size },
      { key: "all", label: "全部", count: @all_actions.size },
      { key: "executed", label: "已执行", count: @executed_actions.size },
      { key: "failed", label: "失败", count: @failed_actions.size }
    ]
  %>
  <% tabs.each do |tab| %>
    <%= link_to agent_actions_path(tab: tab[:key]),
        class: "px-4 py-2 text-sm font-medium border-b-2 -mb-px #{@tab == tab[:key] ? 'text-primary border-primary' : 'text-secondary border-transparent hover:text-primary hover:border-gray-300'}" do %>
      <%= tab[:label] %>
      <% if tab[:count] > 0 %>
        <span class="ml-1 px-1.5 py-0.5 rounded-full text-xs <%= tab[:key] == 'pending' && tab[:count] > 0 ? 'bg-amber-100 text-amber-700' : 'bg-container-inset text-secondary' %>"><%= tab[:count] %></span>
      <% end %>
    <% end %>
  <% end %>
</div>

<%
  actions = case @tab
  when "pending" then @pending_actions
  when "executed" then @executed_actions
  when "failed" then @failed_actions
  else @all_actions
  end
%>

<% if actions.any? %>
  <div class="space-y-2">
    <% actions.each do |action| %>
      <div class="p-3 rounded-lg border border-secondary<%= ' border-amber-200 bg-amber-50/30' if action.pending? %>">
        <div class="flex justify-between items-start">
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1">
              <p class="text-primary text-sm font-medium"><%= action.tool_name %></p>
              <% case action.status %>
              <% when "executed" %>
                <span class="px-1.5 py-0.5 rounded text-xs bg-green-50 text-green-700 border border-green-200">已执行</span>
              <% when "pending" %>
                <span class="px-1.5 py-0.5 rounded text-xs bg-amber-50 text-amber-700 border border-amber-200">待审批</span>
              <% when "failed" %>
                <span class="px-1.5 py-0.5 rounded text-xs bg-red-50 text-red-700 border border-red-200">失败</span>
              <% when "rejected" %>
                <span class="px-1.5 py-0.5 rounded text-xs bg-gray-50 text-gray-600 border border-gray-200">已拒绝</span>
              <% end %>
              <span class="text-xs text-tertiary"><%= action.source %></span>
              <span class="text-xs text-tertiary"><%= action.created_at.strftime("%Y-%m-%d %H:%M") %></span>
            </div>
            <% if action.params.present? && action.params.any? %>
              <p class="text-xs text-secondary truncate">
                参数: <%= action.params.map { |k, v| "#{k}=#{v}" }.join(", ").truncate(120) %>
              </p>
            <% end %>
            <% if action.error_message.present? %>
              <p class="text-xs text-red-600 mt-1"><%= action.error_message.truncate(200) %></p>
            <% end %>
          </div>

          <% if action.pending? %>
            <div class="flex items-center gap-2 shrink-0 ml-4">
              <%= button_to "批准", agent_action_path(action, decision: "approve"), method: :patch,
                  class: "px-3 py-1 text-xs rounded-lg bg-green-600 text-white hover:bg-green-700" %>
              <%= button_to "拒绝", agent_action_path(action, decision: "reject"), method: :patch,
                  class: "px-3 py-1 text-xs rounded-lg border border-red-300 text-red-600 hover:bg-red-50" %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="flex justify-center items-center py-20">
    <div class="text-center">
      <p class="text-sm text-primary font-medium mb-1">暂无<%= @tab == "pending" ? "待审批" : "" %>操作记录</p>
      <p class="text-sm text-secondary">Agent 执行的所有操作都会记录在这里。</p>
    </div>
  </div>
<% end %>
