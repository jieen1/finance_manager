<%# locals: (import:) %>

<div class="h-full flex flex-col justify-center items-center">
  <div class="space-y-6 max-w-sm">
    <div class="mx-auto bg-red-500/5 h-8 w-8 rounded-full flex items-center justify-center">
      <%= icon "alert-octagon", color: "destructive" %>
    </div>

    <div class="text-center space-y-2">
      <h1 class="font-medium text-primary text-center text-3xl">导入失败</h1>
      <p class="text-sm text-secondary">请检查文件格式是否正确、是否存在错误以及所有必填字段是否已填写，然后重新尝试。</p>
    </div>

    <%= render DS::Button.new(text: "重新尝试", href: publish_import_path(import), full_width: true) %>
  </div>
</div>
