<div data-controller="chat hotkey">
  <%= turbo_frame_tag chat_frame do %>
    <%= turbo_stream_from @chat %>

    <h1 class="sr-only"><%= @chat.title %></h1>

    <div class="flex flex-col h-full">
      <%# Aurora AI panel header %>
      <div class="flex items-center gap-3 flex-shrink-0" style="padding:16px 16px 12px;border-bottom:1px solid var(--aurora-bd)">
        <div class="relative flex-shrink-0" style="width:10px;height:10px">
          <div class="aurora-ai-ring"></div>
          <div class="aurora-ai-dot"></div>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-bold text-primary truncate"><%= @chat.title.presence || "AI 助手" %></p>
          <p class="text-xs" style="color:var(--aurora-t2)">AI 分析</p>
        </div>
        <%# Chat history button — uses same "menu" icon as _chat_nav for consistency %>
        <%= link_to chats_path(chat_view: "all"), data: { turbo_frame: chat_frame }, class: "p-1.5 rounded-lg hover:bg-surface-hover text-secondary hover:text-primary transition-colors", title: "对话历史" do %>
          <%= icon("menu", size: "sm") %>
        <% end %>

        <%# Menu with new chat / edit / delete options %>
        <%= render DS::Menu.new(icon_vertical: true) do |menu| %>
          <% menu.with_item(variant: "link", text: "开始新对话", href: new_chat_path, icon: "plus") %>
          <% unless @chat.new_record? %>
            <% menu.with_item(
              variant: "link",
              text: "编辑对话标题",
              href: edit_chat_path(@chat, ctx: "chat"),
              icon: "pencil",
              frame: dom_id(@chat, "title")) %>
            <% menu.with_item(
              variant: "button",
              text: "删除对话",
              href: chat_path(@chat),
              icon: "trash-2",
              method: :delete,
              confirm: CustomConfirm.for_resource_deletion("chat")) %>
          <% end %>
        <% end %>
      </div>

      <%# Messages area %>
      <div id="messages" class="grow overflow-y-auto p-4 space-y-4 pb-24 lg:pb-4 aurora-scroll-hidden" data-chat-target="messages">
        <% if @chat.conversation_messages.any? %>
          <% @chat.conversation_messages.ordered.each do |message| %>
            <%= render message %>
          <% end %>
        <% else %>
          <div class="mt-auto">
            <%= render "chats/ai_greeting", context: "chat" %>
          </div>
        <% end %>

        <% if params[:thinking].present? %>
          <%= render "chats/thinking_indicator", chat: @chat %>
        <% end %>

        <% if @chat.error.present? && @chat.needs_assistant_response? %>
          <%= render "chats/error", chat: @chat %>
        <% end %>
      </div>

      <%# Chat input %>
      <div class="lg:mt-auto fixed lg:static left-0 bottom-16 w-full" style="padding:8px 16px 16px">
        <%= render "messages/chat_form", chat: @chat %>
      </div>
    </div>
  <% end %>
</div>
