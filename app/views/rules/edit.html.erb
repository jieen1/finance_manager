<%= link_to "返回规则列表", rules_path %>

<%= render DS::Dialog.new do |dialog| %>
  <%
    title = if @rule.name.present?
              "编辑#{@rule.resource_type == 'transaction' ? '交易' : @rule.resource_type}规则 \"#{@rule.name}\""
            else
              "编辑#{@rule.resource_type == 'transaction' ? '交易' : @rule.resource_type}规则"
            end
  %>
  <% dialog.with_header(title: title) %>

  <% dialog.with_body do %>
    <%= render "rules/form", rule: @rule %>
  <% end %>
<% end %>
