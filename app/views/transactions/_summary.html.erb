<%# locals: (totals:) %>
<div class="aurora-bento" style="margin-bottom:14px">
  <div class="aurora-card aurora-b-4 aurora-d1" style="padding:16px 18px">
    <div class="aurora-eyebrow mb-2">
      <span class="aurora-eyebrow-dot" style="background:var(--aurora-rose);box-shadow:0 0 6px var(--aurora-rose-glow)"></span>
      <%= t(".expenses") %>
    </div>
    <div class="aurora-stat-val" id="total-expense" style="color:var(--aurora-rose)"><%= totals.expense_money.format %></div>
    <p class="text-xs mt-1" style="color:var(--aurora-t1)"><%= totals.count.round(0) %> 笔交易</p>
  </div>
  <div class="aurora-card aurora-b-4 aurora-d2" style="padding:16px 18px">
    <div class="aurora-eyebrow mb-2">
      <span class="aurora-eyebrow-dot" style="background:var(--aurora-em);box-shadow:0 0 6px var(--aurora-em-glow)"></span>
      <%= t(".income") %>
    </div>
    <div class="aurora-stat-val" id="total-income" style="color:var(--aurora-em)"><%= totals.income_money.format %></div>
    <p class="text-xs mt-1" style="color:var(--aurora-t1)">收入</p>
  </div>
  <div class="aurora-card aurora-b-4 aurora-d3" style="padding:16px 18px">
    <div class="aurora-eyebrow mb-2">
      <span class="aurora-eyebrow-dot" style="background:var(--aurora-blue);box-shadow:0 0 6px var(--aurora-blue-glow)"></span>
      净额
    </div>
    <div class="aurora-stat-val" id="total-transactions" style="color:var(--aurora-em)">
      <%= totals.count.round(0) %>
    </div>
    <p class="text-xs mt-1" style="color:var(--aurora-t1)"><%= t(".total_transactions") %></p>
  </div>
</div>
