<%= content_for :page_title, "API 密钥" %>

<% if @newly_created && @plain_key %>
  <%= settings_section title: "API 密钥已创建", subtitle: "您的新 API 密钥已成功生成。" do %>
    <div class="space-y-4">
      <div class="p-3 shadow-border-xs bg-container rounded-lg">
        <div class="flex items-start gap-3">
          <%= render DS::FilledIcon.new(
            icon: "check-circle",
            rounded: true,
            size: "lg",
            variant: :success
          ) %>
          <div class="flex-1">
            <h3 class="font-medium text-primary">API 密钥创建成功！</h3>
            <p class="text-secondary text-sm mt-1">您的新 API 密钥 "<%= @current_api_key.name %>" 已创建，可以立即使用。</p>
          </div>
        </div>
      </div>

      <div class="bg-surface-inset rounded-xl p-4">
        <h4 class="font-medium text-primary mb-3">您的 API 密钥</h4>
        <p class="text-secondary text-sm mb-3">请复制并安全保存此密钥...</p>

        <div class="bg-container rounded-lg p-3 border border-primary" data-controller="clipboard">
          <div class="flex items-center justify-between gap-3">
            <code id="api-key-display" class="font-mono text-sm text-primary break-all" data-clipboard-target="source"><%= @current_api_key.plain_key %></code>
            <%= render DS::Button.new(
              text: "复制 API 密钥",
              variant: "ghost",
              icon: "copy",
              data: { action: "clipboard#copy" }
            ) %>
          </div>
        </div>
      </div>

      <div class="bg-surface-inset rounded-xl p-4">
        <h4 class="font-medium text-primary mb-3">如何使用 API 密钥</h4>
        <p class="text-secondary text-sm mb-3">在请求头中添加 X-Api-Key 字段：</p>
        <div class="bg-container rounded-lg p-3 font-mono text-sm text-primary border border-primary">
          curl -H "X-Api-Key: <%= @current_api_key.plain_key %>" <%= request.base_url %>/api/v1/accounts
        </div>
      </div>

      <div class="flex justify-end pt-4 border-t border-primary">
        <%= render DS::Link.new(
          text: "前往 API 密钥设置",
          href: settings_api_key_path,
          variant: "primary"
        ) %>
      </div>
    </div>
  <% end %>
<% elsif @current_api_key %>
  <%= settings_section title: "您的 API 密钥", subtitle: "管理您的 API 密钥以通过程序访问财务数据。" do %>
    <div class="space-y-4">
      <div class="p-3 shadow-border-xs bg-container rounded-lg flex justify-between items-center">
        <div class="flex items-center gap-3">
          <%= render DS::FilledIcon.new(
            icon: "key",
            rounded: true,
            size: "lg"
          ) %>

          <div class="text-sm space-y-1">
            <p class="text-primary font-medium"><%= @current_api_key.name %></p>
            <p class="text-secondary">
              创建于 <%= time_ago_in_words(@current_api_key.created_at) %>前
              <% if @current_api_key.last_used_at %>
                • 上次使用于 <%= time_ago_in_words(@current_api_key.last_used_at) %>前
              <% else %>
                • 从未使用
              <% end %>
            </p>
          </div>
        </div>

        <div class="rounded-md bg-success px-2 py-1">
          <p class="text-success-foreground font-medium text-xs">活跃</p>
        </div>
      </div>

      <div class="bg-surface-inset rounded-xl p-4">
        <h4 class="font-medium text-primary mb-3">权限</h4>
        <div class="flex flex-wrap gap-2">
          <% @current_api_key.scopes.each do |scope| %>
            <span class="inline-flex items-center gap-1 px-2 py-1 bg-primary text-primary-foreground rounded-full text-xs font-medium">
              <%= icon("shield-check", class: "w-3 h-3") %>
              <%= case scope
                  when "read" then "只读"
                  when "read_write" then "读写"
                  else scope.humanize
                  end %>
            </span>
          <% end %>
        </div>
      </div>

      <div class="bg-surface-inset rounded-xl p-4">
        <h4 class="font-medium text-primary mb-3">您的 API 密钥</h4>
        <p class="text-secondary text-sm mb-3">请复制并安全保存此密钥...</p>

        <div class="bg-container rounded-lg p-3 border border-primary" data-controller="clipboard">
          <div class="flex items-center justify-between gap-3">
            <code id="api-key-display" class="font-mono text-sm text-primary break-all" data-clipboard-target="source"><%= @current_api_key.plain_key %></code>
            <%= render DS::Button.new(
              text: "复制 API 密钥",
              variant: "ghost",
              icon: "copy",
              data: { action: "clipboard#copy" }
            ) %>
          </div>
        </div>
      </div>

      <div class="bg-surface-inset rounded-xl p-4">
        <h4 class="font-medium text-primary mb-3">如何使用 API 密钥</h4>
        <p class="text-secondary text-sm mb-3">在请求头中添加 X-Api-Key 字段：</p>
        <div class="bg-container rounded-lg p-3 font-mono text-sm text-primary border border-primary">
          curl -H "X-Api-Key: <%= @current_api_key.plain_key %>" <%= request.base_url %>/api/v1/accounts
        </div>
      </div>

      <div class="flex flex-col sm:flex-row gap-3 pt-4 border-t border-primary">
        <%= render DS::Link.new(
          text: "创建新密钥",
          href: new_settings_api_key_path(regenerate: true),
          variant: "secondary"
        ) %>

        <%= render DS::Button.new(
          text: "撤销密钥",
          href: settings_api_key_path,
          method: :delete,
          variant: "destructive",
          data: {
            turbo_confirm: "确定要撤销此 API 密钥吗？"
          }
        ) %>
      </div>
    </div>
  <% end %>
<% else %>
  <%= settings_section title: "创建 API 密钥", subtitle: "通过程序访问您的财务数据" do %>
    <div class="space-y-4">
      <div class="p-3 shadow-border-xs bg-container rounded-lg">
        <div class="flex items-start gap-3">
          <%= render DS::FilledIcon.new(
            icon: "key",
            rounded: true,
            size: "lg"
          ) %>
          <div class="flex-1">
            <h3 class="font-medium text-primary">通过程序访问账户数据</h3>
            <p class="text-secondary text-sm mt-1">生成 API 密钥以连接您的应用程序并安全访问财务数据。</p>
          </div>
        </div>
      </div>

      <div class="bg-surface-inset rounded-xl p-4">
        <h4 class="font-medium text-primary mb-3">API 密钥可以用来：</h4>
        <ul class="space-y-2 text-sm text-secondary">
          <li class="flex items-start gap-2">
            <%= icon("check", class: "w-4 h-4 text-primary mt-0.5") %>
            <span>访问账户和余额</span>
          </li>
          <li class="flex items-start gap-2">
            <%= icon("check", class: "w-4 h-4 text-primary mt-0.5") %>
            <span>查看交易历史</span>
          </li>
          <li class="flex items-start gap-2">
            <%= icon("check", class: "w-4 h-4 text-primary mt-0.5") %>
            <span>创建新交易</span>
          </li>
          <li class="flex items-start gap-2">
            <%= icon("check", class: "w-4 h-4 text-primary mt-0.5") %>
            <span>与第三方应用集成</span>
          </li>
        </ul>
      </div>

      <div class="flex justify-start">
        <%= render DS::Link.new(
          text: "创建 API 密钥",
          href: new_settings_api_key_path,
          variant: "primary"
        ) %>
      </div>
    </div>
  <% end %>
<% end %>
