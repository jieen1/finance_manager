<%= content_for :page_title, "API 密钥已创建" %>

<%= settings_section title: "API 密钥创建成功", subtitle: "您的新 API 密钥已成功生成。" do %>
  <div class="space-y-4">
    <div class="p-3 shadow-border-xs bg-container rounded-lg">
      <div class="flex items-start gap-3">
        <%= render DS::FilledIcon.new(
          icon: "check-circle",
          rounded: true,
          size: "lg",
          variant: :success
        ) %>
        <div class="flex-1">
          <h3 class="font-medium text-primary">API 密钥创建成功！</h3>
          <p class="text-secondary text-sm mt-1">您的新 API 密钥 "<%= @api_key.name %>" 已创建，可以立即使用。</p>
        </div>
      </div>
    </div>

    <div class="bg-surface-inset rounded-xl p-4">
      <h4 class="font-medium text-primary mb-3">您的 API 密钥</h4>
      <p class="text-secondary text-sm mb-3">请复制并安全保存此密钥，您需要用它来验证 API 请求。</p>

      <div class="bg-container rounded-lg p-3 border border-primary" data-controller="clipboard">
        <div class="flex items-center justify-between gap-3">
          <code id="api-key-display" class="font-mono text-sm text-primary break-all" data-clipboard-target="source"><%= @api_key.plain_key %></code>
          <%= render DS::Button.new(
            text: "复制 API 密钥",
            variant: "ghost",
            icon: "copy",
            data: { action: "clipboard#copy" }
          ) %>
        </div>
      </div>
    </div>

    <div class="bg-surface-inset rounded-xl p-4">
      <h4 class="font-medium text-primary mb-3">密钥信息</h4>
      <div class="space-y-2 text-sm">
        <div class="flex justify-between">
          <span class="text-secondary">名称：</span>
          <span class="text-primary font-medium"><%= @api_key.name %></span>
        </div>
        <div class="flex justify-between">
          <span class="text-secondary">权限：</span>
          <span class="text-primary">
            <%= @api_key.scopes.map { |scope|
              case scope
              when "read_accounts" then "查看账户"
              when "read_transactions" then "查看交易"
              when "read_balances" then "查看余额"
              when "write_transactions" then "创建交易"
              else scope.humanize
              end
            }.join(", ") %>
          </span>
        </div>
        <div class="flex justify-between">
          <span class="text-secondary">创建时间：</span>
          <span class="text-primary"><%= @api_key.created_at.strftime("%B %d, %Y at %I:%M %p") %></span>
        </div>
      </div>
    </div>

    <div class="bg-warning-50 border border-warning-200 rounded-xl p-4">
      <div class="flex items-start gap-2">
        <%= icon("alert-triangle", class: "w-5 h-5 text-warning-600 mt-0.5") %>
        <div>
          <h4 class="font-medium text-warning-800 text-sm">重要安全提示</h4>
          <p class="text-warning-700 text-sm mt-1">
            此 API 密钥只会显示一次，请立即复制并安全保存。关闭此页面后将无法再次查看完整密钥。
          </p>
        </div>
      </div>
    </div>

    <div class="bg-surface-inset rounded-xl p-4">
      <h4 class="font-medium text-primary mb-3">如何使用 API 密钥</h4>
      <p class="text-secondary text-sm mb-3">在请求头中添加 X-Api-Key 字段：</p>
      <div class="bg-container rounded-lg p-3 font-mono text-sm text-primary border border-primary">
        curl -H "X-Api-Key: <%= @api_key.plain_key %>" <%= request.base_url %>/api/v1/accounts
      </div>
    </div>

    <div class="flex justify-end pt-4 border-t border-primary">
      <%= render DS::Link.new(
        text: "前往 API 密钥设置",
        href: settings_api_key_path,
        variant: "primary"
      ) %>
    </div>
  </div>
<% end %>
