<%# locals:(name:, path:, icon:, icon_custom:, active:, mobile_only: false) %>

<%= link_to path, class: "space-y-1 group block relative pb-1" do %>
  <div class="grow flex flex-col lg:flex-row gap-1 items-center">
    <%= tag.div class: class_names("w-4 h-1 lg:w-1 lg:h-4 rounded-bl-sm rounded-br-sm lg:rounded-tr-sm lg:rounded-br-sm lg:rounded-bl-none", active ? "bg-nav-indicator" : "") %>

    <%= tag.div class: class_names(
      "w-8 h-8 flex items-center justify-center mx-auto rounded-lg transition-all duration-200",
      active ? "text-primary" : "group-hover:bg-surface-hover text-secondary"
    ), style: active ? "color:var(--aurora-em);background:var(--aurora-em-dim)" : "" do %>
      <%= icon(icon, color: active ? "current" : "default", custom: icon_custom) %>
    <% end %>
  </div>

  <div class="grow flex justify-center lg:pl-2">
    <%= tag.p class: class_names("font-medium text-[11px]", active ? "text-primary" : "text-secondary") do %>
      <%= name %>
    <% end %>
  </div>
<% end %>
