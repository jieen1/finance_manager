<%# locals: (breadcrumbs:) %>

<div class="flex items-center gap-1.5" style="font-size:13px;font-weight:500;color:var(--aurora-t1)">
  <% breadcrumbs.each_with_index do |(name, path), index| %>
    <% if index > 0 %>
      <%= icon("chevron-right", color: "gray", size: "sm") %>
    <% end %>

    <% if path.present? && index < breadcrumbs.size - 1 %>
      <%= link_to name, path, style: "color:var(--aurora-t1)" %>
    <% elsif index == breadcrumbs.size - 1 %>
      <span class="font-semibold" style="color:var(--aurora-t0)"><%= name %></span>
    <% else %>
      <span style="color:var(--aurora-t1)"><%= name %></span>
    <% end %>
  <% end %>
</div>
