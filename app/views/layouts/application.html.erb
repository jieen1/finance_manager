<% mobile_nav_items = [
  { name: "首页", path: root_path, icon: "pie-chart", icon_custom: false, active: page_active?(root_path) },
  { name: "交易", path: transactions_path, icon: "credit-card", icon_custom: false, active: page_active?(transactions_path) },
  { name: "预算", path: budgets_path, icon: "map", icon_custom: false, active: page_active?(budgets_path) },
  { name: "助手", path: chats_path, icon: "icon-assistant", icon_custom: true, active: page_active?(chats_path), mobile_only: true }
] %>

<% desktop_nav_items = mobile_nav_items.reject { |item| item[:mobile_only] } %>
<% expanded_sidebar_class = "w-full" %>
<% collapsed_sidebar_class = "w-0" %>

<%= render "layouts/shared/htmldoc" do %>
  <div
    class="flex flex-col lg:flex-row h-full"
    style="background: var(--aurora-bg-0)"
    data-controller="app-layout"
    data-app-layout-expanded-sidebar-class="<%= expanded_sidebar_class %>"
    data-app-layout-collapsed-sidebar-class="<%= collapsed_sidebar_class %>"
    data-app-layout-user-id-value="<%= Current.user.id %>">

    <%# MOBILE - Sidebar overlay %>
    <div
      class="hidden fixed inset-0 z-20 h-full w-full pt-[calc(env(safe-area-inset-top)+0.75rem)] pr-3 pb-[calc(env(safe-area-inset-bottom)+0.75rem)] pl-3 overflow-y-auto transition-all duration-300"
      style="background: var(--aurora-bg-0)"
      data-app-layout-target="mobileSidebar">
      <div class="mb-2">
        <%= icon("x", as_button: true, data: { action: "app-layout#closeMobileSidebar" }) %>
      </div>
      <%= render(
        "accounts/account_sidebar_tabs",
        family: Current.family,
        active_tab: @account_group_tab,
        mobile: true
      ) %>
    </div>

    <%# MOBILE - Top nav %>
    <nav class="lg:hidden flex justify-between items-center p-3" style="background: var(--aurora-bg-1)">
      <%= icon("panel-left", as_button: true, data: { action: "app-layout#openMobileSidebar"}) %>

      <%= link_to root_path, class: "block" do %>
        <svg viewBox="0 0 36 36" fill="none" class="w-9 h-9 mx-auto">
          <rect x="2" y="2" width="32" height="32" rx="10" fill="var(--aurora-bg-3)"/>
          <path d="M9 24 C12 22 15 14 18 12 C21 10 24 18 27 10" stroke="url(#logoG)" stroke-width="2.5" stroke-linecap="round" fill="none"/>
          <circle cx="27" cy="10" r="2.5" fill="#10b981" filter="drop-shadow(0 0 4px rgba(16,185,129,.6))"/>
        </svg>
      <% end %>

      <%= render "users/user_menu", user: Current.user, placement: "bottom-end", offset: 12 %>
    </nav>

    <%# DESKTOP - Aurora Nav (icon-only dock) %>
    <div class="hidden lg:block">
      <nav class="aurora-nav h-full">
        <%# Logo %>
        <div class="flex items-center justify-center mb-4 flex-shrink-0">
          <%= link_to root_path, class: "block" do %>
            <svg viewBox="0 0 36 36" fill="none" class="w-8 h-8 transition-transform duration-300 hover:scale-110">
              <rect x="2" y="2" width="32" height="32" rx="10" fill="var(--aurora-bg-3)"/>
              <path d="M9 24 C12 22 15 14 18 12 C21 10 24 18 27 10" stroke="url(#logoG)" stroke-width="2.5" stroke-linecap="round" fill="none"/>
              <circle cx="27" cy="10" r="2.5" fill="#10b981" filter="drop-shadow(0 0 4px rgba(16,185,129,.6))"/>
            </svg>
          <% end %>
        </div>

        <%# Nav items %>
        <div class="flex flex-col gap-1 w-full px-2 flex-1">
          <% desktop_nav_items.each do |nav_item| %>
            <%= link_to nav_item[:path], class: "aurora-nav-icon #{'active' if nav_item[:active]}", title: nav_item[:name] do %>
              <%= icon(nav_item[:icon], custom: nav_item[:icon_custom]) %>
            <% end %>
          <% end %>

          <%= link_to settings_profile_path, class: "aurora-nav-icon #{'active' if page_active?(settings_profile_path)}", title: "设置" do %>
            <%= icon("settings") %>
          <% end %>
        </div>

        <%# Bottom avatar %>
        <div class="mt-auto w-full flex justify-center pb-2">
          <%= render "users/user_menu", user: Current.user %>
        </div>
      </nav>
    </div>

    <%# DESKTOP - Left sidebar (accounts) %>
    <%= tag.div class: class_names(
        "hidden lg:flex flex-col flex-shrink-0 overflow-y-auto aurora-scroll-hidden transition-all duration-300",
        Current.user.show_sidebar? ? expanded_sidebar_class : collapsed_sidebar_class,
       ),
       style: "max-width:280px;background:var(--aurora-glass);backdrop-filter:blur(20px) saturate(180%);-webkit-backdrop-filter:blur(20px) saturate(180%);border-right:1px solid var(--aurora-glass-b)",
       data: { app_layout_target: "leftSidebar" } do %>
      <% if content_for?(:sidebar) %>
        <%= yield :sidebar %>
      <% else %>
        <div class="h-full flex flex-col">
          <div class="overflow-y-auto grow aurora-scroll-hidden">
            <%= render "accounts/account_sidebar_tabs", family: Current.family, active_tab: @account_group_tab %>
          </div>

        </div>
      <% end %>
    <% end %>

    <%# SHARED - Main content %>
    <div class="flex-1 flex flex-col min-w-0">
      <%# Aurora topbar %>
      <div class="hidden lg:flex aurora-topbar">
        <div class="flex items-center gap-2">
          <button class="aurora-btn-ghost p-1.5" data-action="app-layout#toggleLeftSidebar">
            <%= icon("panel-left", size: "sm") %>
          </button>

          <% if content_for?(:breadcrumbs) %>
            <%= yield :breadcrumbs %>
          <% else %>
            <%= render "layouts/shared/breadcrumbs", breadcrumbs: @breadcrumbs %>
          <% end %>
        </div>

        <div class="flex items-center gap-2">
          <%= render DS::Link.new(
            icon: "plus",
            text: "添加",
            href: new_account_path,
            frame: :modal,
            class: "aurora-btn-primary"
          ) %>
          <button class="aurora-btn-ghost p-1.5" data-action="app-layout#toggleRightSidebar">
            <%= icon("panel-right", size: "sm") %>
          </button>
        </div>
      </div>

      <%# Scrollable content area %>
      <%= tag.main class: "flex-1 overflow-y-auto px-3 lg:px-6 py-4 aurora-scroll", data: { app_layout_target: "content" } do %>
        <% if content_for?(:page_header) %>
          <%= yield :page_header %>
        <% end %>
        <%= yield %>
      <% end %>
    </div>

    <%# DESKTOP - Right sidebar (AI chat) %>
    <%= tag.div class: class_names(
          "hidden lg:flex flex-col h-full flex-shrink-0 overflow-y-auto transition-all duration-300",
          Current.user.show_ai_sidebar? ? expanded_sidebar_class : collapsed_sidebar_class,
        ),
        style: "max-width:420px;background:var(--aurora-glass);backdrop-filter:blur(20px) saturate(180%);-webkit-backdrop-filter:blur(20px) saturate(180%);border-left:1px solid var(--aurora-glass-b)",
        data: { app_layout_target: "rightSidebar" } do %>
      <%= tag.div id: "chat-container", class: "relative h-full", data: { controller: "chat hotkey", turbo_permanent: true } do %>
        <div class="flex flex-col h-full justify-between shrink-0">
          <%= turbo_frame_tag chat_frame, src: chat_view_path(@chat), loading: "lazy", class: "h-full" do %>
            <div class="flex justify-center items-center h-full">
              <%= icon("loader-circle", class: "animate-spin") %>
            </div>
          <% end %>
        </div>

        <% unless Current.user.ai_enabled? %>
          <div class="absolute backdrop-blur-lg inset-0 h-full w-full flex flex-col justify-center items-center pl-0.5 pr-4">
            <%= render "chats/ai_consent" %>
          </div>
        <% end %>
      <% end %>
    <% end %>

    <%# MOBILE - Bottom Nav %>
    <%= tag.nav class: "lg:hidden shrink-0 z-10 pb-[env(safe-area-inset-bottom)] flex justify-around",
               style: "background:var(--aurora-bg-1);border-top:1px solid var(--aurora-bd)" do %>
      <% mobile_nav_items.each do |nav_item| %>
        <%= render "layouts/shared/nav_item", **nav_item %>
      <% end %>
    <% end %>
  </div>

  <%# SVG gradients for logo %>
  <svg style="width:0;height:0;position:absolute" aria-hidden="true">
    <defs>
      <linearGradient id="logoG" x1="0" y1="1" x2="1" y2="0">
        <stop offset="0%" stop-color="#059669"/>
        <stop offset="100%" stop-color="#6ee7b7"/>
      </linearGradient>
    </defs>
  </svg>
<% end %>
