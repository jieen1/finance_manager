<%= content_for :page_title, "任务中心" %>

<header class="flex items-center justify-between mb-4">
  <div class="flex items-center gap-2">
    <h1 class="text-primary text-xl font-medium">任务中心</h1>
    <% if @active_count > 0 %>
      <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-green-50 text-green-600 border border-green-200"><%= @active_count %> 运行中</span>
    <% end %>
  </div>
  <%= render DS::Link.new(
    text: "新建任务",
    variant: "primary",
    href: new_agent_task_path,
    icon: "plus",
    frame: :modal
  ) %>
</header>

<% if @tasks.any? %>
  <div class="space-y-2">
    <% @tasks.each do |task| %>
      <div class="p-4 rounded-lg border border-secondary hover:bg-surface-hover transition-colors">
        <div class="flex justify-between items-start">
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1">
              <p class="text-primary text-sm font-medium"><%= task.name %></p>
              <span class="px-1.5 py-0.5 rounded text-xs bg-blue-50 text-blue-600 border border-blue-200"><%= task.action_label %></span>
              <% if task.system? %>
                <span class="px-1.5 py-0.5 rounded text-xs bg-gray-100 text-gray-600 border border-gray-300">系统</span>
              <% elsif task.agent_created? %>
                <span class="px-1.5 py-0.5 rounded text-xs bg-purple-50 text-purple-600 border border-purple-200">AI</span>
              <% end %>
              <% case task.status %>
              <% when "active" %>
                <span class="px-1.5 py-0.5 rounded text-xs bg-green-50 text-green-600 border border-green-200">运行中</span>
              <% when "paused" %>
                <span class="px-1.5 py-0.5 rounded text-xs bg-gray-50 text-gray-500 border border-gray-200">已暂停</span>
              <% when "completed" %>
                <span class="px-1.5 py-0.5 rounded text-xs bg-purple-50 text-purple-600 border border-purple-200">已完成</span>
              <% when "failed" %>
                <span class="px-1.5 py-0.5 rounded text-xs bg-red-50 text-red-600 border border-red-200">失败</span>
              <% end %>
            </div>
            <div class="flex items-center gap-3 text-xs text-secondary">
              <span><%= task.schedule_label %></span>
              <% if task.last_run_at %>
                <span>上次: <%= task.last_run_at.strftime("%m-%d %H:%M") %></span>
              <% end %>
              <% if task.next_run_at && task.active? %>
                <span>下次: <%= task.next_run_at.strftime("%m-%d %H:%M") %></span>
              <% end %>
              <span>已执行 <%= task.run_count %> 次</span>
            </div>
            <% if task.last_error.present? %>
              <p class="text-xs text-red-500 mt-1"><%= task.last_error.truncate(100) %></p>
            <% end %>
            <% if task.description.present? %>
              <p class="text-xs text-secondary mt-1"><%= task.description.truncate(100) %></p>
            <% end %>
          </div>

          <div class="flex items-center gap-2 shrink-0 ml-4">
            <% if task.active? %>
              <%= button_to "执行", execute_agent_task_path(task), method: :post,
                  class: "px-2 py-1 text-xs rounded border border-secondary text-secondary hover:text-primary hover:border-primary transition-colors" %>
            <% end %>
            <%= render DS::Menu.new do |menu| %>
              <% menu.with_item(variant: "link", text: "编辑", icon: "pencil", href: edit_agent_task_path(task), data: { turbo_frame: "modal" }) %>
              <% if task.active? %>
                <% menu.with_item(variant: "button", text: "暂停", icon: "pause", href: agent_task_path(task, action_type: "pause"), method: :patch) %>
              <% elsif task.paused? %>
                <% menu.with_item(variant: "button", text: "恢复", icon: "play", href: agent_task_path(task, action_type: "resume"), method: :patch) %>
              <% end %>
              <% unless task.system? %>
              <% menu.with_item(
                variant: "button",
                text: "删除",
                icon: "trash-2",
                href: agent_task_path(task),
                method: :delete,
                confirm: CustomConfirm.new(title: "删除任务？", body: "确定要删除 \"#{task.name}\" 吗？", btn_text: "删除", destructive: true)) %>
              <% end %>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="flex justify-center items-center py-20 border border-secondary rounded-lg">
    <div class="text-center">
      <p class="text-sm text-primary font-medium mb-1">暂无任务</p>
      <p class="text-sm text-secondary mb-4">创建定时任务让 Agent 自动执行分析、记账等操作。也可以在对话中让 AI 帮你创建。</p>
      <%= render DS::Link.new(
        text: "新建任务",
        variant: "primary",
        href: new_agent_task_path,
        icon: "plus",
        frame: :modal
      ) %>
    </div>
  </div>
<% end %>
