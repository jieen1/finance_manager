<%= render DS::Dialog.new do |dialog| %>
  <% dialog.with_header(title: "新建任务") %>
  <% dialog.with_body do %>
    <%= styled_form_with model: @agent_task, url: agent_tasks_path, class: "space-y-4" do |f| %>
      <% if @agent_task.errors.any? %>
        <%= render "shared/form_errors", model: @agent_task %>
      <% end %>

      <%= f.text_field :name, label: "任务名称", placeholder: "例如：每周财务报告", required: true %>

      <%= f.text_area :description, label: "描述", rows: 2, placeholder: "任务的详细说明（可选）" %>

      <%= f.select :action_type,
          [
            ["月度报告", "skill_monthly_report"],
            ["健康评分", "skill_health_score"],
            ["异常检测", "skill_detect_anomalies"],
            ["配置分析", "skill_asset_allocation"],
            ["订阅识别", "skill_detect_subscriptions"],
            ["自动分类", "auto_categorize"],
            ["截图扫描", "ocr_scan"],
            ["心跳检查", "heartbeat_check"],
            ["自定义", "custom"]
          ],
          { label: "执行操作" } %>

      <%= f.select :schedule_type,
          [["间隔执行", "every"], ["一次性", "once"], ["Cron 表达式", "cron"]],
          { label: "调度类型" } %>

      <%= f.select :interval_minutes,
          [["每5分钟", 5], ["每15分钟", 15], ["每30分钟", 30], ["每小时", 60], ["每6小时", 360], ["每天", 1440], ["每周", 10080]],
          { label: "执行间隔（间隔执行时）" } %>

      <%= f.text_field :cron_expression, label: "Cron 表达式（Cron 类型时）", placeholder: "0 8 * * 1（每周一8点）" %>

      <%= f.datetime_local_field :run_at, label: "执行时间（一次性时）" %>

      <%= f.submit "创建任务" %>
    <% end %>
  <% end %>
<% end %>
