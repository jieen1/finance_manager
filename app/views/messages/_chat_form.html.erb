<%# locals: (chat: nil, message_hint: nil) %>

<div id="chat-form" class="space-y-2">
  <% model = chat && chat.persisted? ? [chat, Message.new] : Chat.new %>

  <%= form_with model: model,
                class: "aurora-chat-input",
                data: { chat_target: "form" } do |f| %>

    <%= f.hidden_field :ai_model, value: ENV.fetch("MINIMAX_MODEL_NAME", "MiniMax-Text-01") %>

    <%= f.text_area :content, placeholder: "随便问点什么...", value: message_hint,
                  class: "w-full border-0 focus:ring-0 text-sm resize-none bg-transparent text-primary placeholder:text-subdued px-1",
                  data: { chat_target: "input", action: "input->chat#autoResize keydown->chat#handleInputKeyDown" },
                  rows: 1 %>

    <div class="flex items-center justify-between gap-1 mt-1">
      <div class="items-center gap-1 hidden lg:flex">
        <% ["plus", "command", "at-sign", "mouse-pointer-click"].each do |ic| %>
          <%= icon(ic, as_button: true, disabled: true, class: "cursor-not-allowed opacity-30", title: "即将推出") %>
        <% end %>
      </div>

      <button type="submit" class="aurora-chat-send">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
      </button>
    </div>
  <% end %>

</div>
