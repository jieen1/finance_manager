<%# locals: (pagy:) %>

<nav class="flex w-full items-center justify-between">
  <div class="flex items-center gap-1">
    <div>
      <% if pagy.prev %>
        <%= link_to pagy_url_for(pagy, pagy.prev),
              data: {},
              class: "inline-flex items-center p-1.5 text-sm rounded-lg transition-colors duration-150",
              style: "color:var(--aurora-t2)" do %>
          <%= icon("chevron-left") %>
        <% end %>
      <% else %>
        <div class="inline-flex items-center p-1.5 text-sm" style="color:var(--aurora-t3)">
          <%= icon("chevron-left") %>
        </div>
      <% end %>
    </div>
    <div class="flex items-center gap-0.5 rounded-lg p-0.5" style="background:var(--aurora-bg-3)">
      <% pagy.series.each do |series_item| %>
        <% if series_item.is_a?(Integer) %>
          <%= link_to pagy_url_for(pagy, series_item),
                data: {},
                class: "rounded-md px-2.5 py-1 inline-flex items-center text-xs font-medium transition-colors duration-150",
                style: "color:var(--aurora-t2)" do %>
            <%= series_item %>
          <% end %>
        <% elsif series_item.is_a?(String) %>
          <%= link_to pagy_url_for(pagy, series_item),
                data: {},
                class: "rounded-md px-2.5 py-1 inline-flex items-center text-xs font-bold",
                style: "background:var(--aurora-em-dim);color:var(--aurora-em)" do %>
            <%= series_item %>
          <% end %>
        <% elsif series_item == :gap %>
          <span class="inline-flex items-center px-1.5 py-1 text-xs" style="color:var(--aurora-t2)">...</span>
        <% end %>
      <% end %>
    </div>
    <div>
      <% if pagy.next %>
        <%= link_to pagy_url_for(pagy, pagy.next),
              data: {},
              class: "inline-flex items-center p-1.5 text-sm rounded-lg transition-colors duration-150",
              style: "color:var(--aurora-t2)" do %>
          <%= icon("chevron-right") %>
        <% end %>
      <% else %>
        <div class="inline-flex items-center p-1.5 text-sm" style="color:var(--aurora-t3)">
          <%= icon("chevron-right") %>
        </div>
      <% end %>
    </div>
  </div>
  <div class="flex items-center">
    <div class="aurora-select-wrap" data-controller="aurora-select">
      <%= select_tag :per_page,
                     options_for_select(["10", "20", "30", "50"], pagy.limit),
                     data: { controller: "selectable-link", "aurora-select-target": "select" } %>
    </div>
  </div>
</nav>
